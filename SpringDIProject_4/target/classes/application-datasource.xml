<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- 
		1. 데이터베이스 정보 수집 : BasicDataSource
			= driver / url / username / password / maxActive
			maxIdle / maxWait
			= 8, 8, 10000
		2. MyBatis 연결 SqlSessionFactoryBean => 데이터베이스 정보 수집
		3. Mapper 구현	MapperFactoryBean => SqlSessionFactoryBean
	 -->
	 <bean id="ds" class="org.apache.commons.dbcp.BasicDataSource"
	 	p:driverClassName="oracle.jdbc.driver.OracleDriver"
	 	p:url="jdbc:oracle:thin:@localhost:1521:XE"
	 	p:username="hr"
	 	p:password="happy"
	 />
	 <bean id="ssf" class="org.mybatis.spring.SqlSessionFactoryBean"
	 	p:dataSource-ref="ds"
	 />
	 <!-- 반복이 많이 발생 -->
	 <bean id="fMapper" class="org.mybatis.spring.mapper.MapperFactoryBean"
	 	p:sqlSessionFactory-ref="ssf"
	 	p:mapperInterface="com.sist.mapper.FoodMapper"
	 />
	 <bean id="sMapper" class="org.mybatis.spring.mapper.MapperFactoryBean"
	 	p:sqlSessionFactory-ref="ssf"
	 	p:mapperInterface="com.sist.mapper.SeoulMapper"
	 />
	 <bean id="gMapper" class="org.mybatis.spring.mapper.MapperFactoryBean"
	 	p:sqlSessionFactory-ref="ssf"
	 	p:mapperInterface="com.sist.mapper.GoodsMapper"
	 />

</beans>
